# Core
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me

# Database
DATABASE_URL=postgresql+asyncpg://wandr:wandr@localhost:5433/wandr

# Vector search
QDRANT_URL=http://localhost:6335
QDRANT_API_KEY=

# Cache
REDIS_URL=

# LLM
LLM_MODEL=nvidia_nim/meta/llama-3.1-8b-instruct
LLM_API_KEY=change-me
LLM_API_BASE=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=4

# Planner agent bounds
PLANNER_MAX_TOOL_CALLS=12
PLANNER_MAX_REPLAN_ATTEMPTS=2
PLANNER_GENERATION_TIMEOUT_SECONDS=45
PLANNER_MIN_READINESS_SCORE=0.3
PLANNER_AGENT_PHASE_STUCK_LIMIT=3

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Geo
NOMINATIM_USER_AGENT=wandr-dev/0.1 (contact@example.com)
OSRM_BASE_URL=https://router.project-osrm.org
